# 리허설시티 환경변수 예시
# 사용법: cp .env.example .env 후 실제 값 입력. .env 는 절대 커밋 금지.

# === 데이터베이스 (docker-compose.yml 의 PostGIS 컨테이너와 일치시킬 것) ===
POSTGRES_USER=rehearsal
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=rehearsal_city
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# 애플리케이션이 사용하는 최종 접속 URL (위 값들로 조립)
DATABASE_URL=postgresql+psycopg://rehearsal:change_me_in_local_env@localhost:5432/rehearsal_city

# === 공공 API 인증키 (docs/DATA.md 참조) ===
# 공공데이터포털 data.go.kr — 소상공인시장진흥공단 상가(상권)정보
DATA_GO_KR_API_KEY=
# 서울 열린데이터광장 data.seoul.go.kr — 생활인구, 상권분석서비스
SEOUL_OPENDATA_API_KEY=
# KOSIS 공유서비스 kosis.kr — 인구·가구 통계
KOSIS_API_KEY=

# === LLM (Phase 3 전까지 미사용 — 원칙 5) ===
# Claude API (Haiku급, 시민 전환점 의사결정용)
ANTHROPIC_API_KEY=

# === 데모 지역 설정 (하드코딩 금지 — config 로 관리) ===
TARGET_REGION=서울특별시 성동구 성수동
